# Required
SECRET_KEY=your-random-secret-key

# Database (default: SQLite at instance/app.db)
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/seetran

# Anthropic API (required for agents)
CLAUDE_API_KEY=sk-ant-...

# OAuth — Google
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# OAuth — Microsoft
# OAUTH_MS_CLIENT_ID=
# OAUTH_MS_CLIENT_SECRET=

# Email notifications (Postmark)
# POSTMARK_API_KEY=
# POSTMARK_SENDER_EMAIL=

# Bypass all auth checks (dev/testing only)
# SUPER_ADMIN_EMAIL=you@example.com

# Agent model overrides (default: claude-sonnet-4-20250514)
# AGENCY_AGENT_MODEL=
# VENDOR_AGENT_MODEL=
# COMPONENT_AGENT_MODEL=
